# --- Docker Compose: Postgres service (not read by the FastAPI app) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_db

# --- Application ---
# Database URL
# For Docker: use 'db' as hostname (service name from docker-compose.yml)
# For local: use 'localhost' as hostname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/app_db
#
# Tests: pytest creates a separate database named app_db_test (via CREATE DATABASE);
# the Postgres user must be allowed to create databases.

# Application Settings
DEBUG=False

# uv Configuration (optional)
# Uncomment if you want uv to use your system Python (e.g., when using pyenv)
# instead of managing its own Python installation
# UV_USE_SYSTEM_PYTHON=1

# CORS Configuration
# For development: use "*" to allow all origins
# For production: specify comma-separated list of allowed origins
# Example: CORS_ORIGINS=https://example.com,https://app.example.com
CORS_ORIGINS=*
CORS_CREDENTIALS=True
CORS_METHODS=*
CORS_HEADERS=*

# Request Logging
# Set to False to disable request/response logging middleware
LOG_REQUESTS=True

# JWT (access + refresh; login and POST /api/v1/auth/refresh)
JWT_SECRET_KEY=change-this-jwt-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Auth route rate limits (slowapi; e.g. requests per minute per client IP)
RATE_LIMIT_AUTH_REGISTER=5/minute
RATE_LIMIT_AUTH_LOGIN=10/minute
RATE_LIMIT_AUTH_REFRESH=30/minute

# Anonymous agent trial (public routes; optional pepper to harden token hashes)
ANONYMOUS_AGENT_TOKEN_PEPPER=
ANONYMOUS_AGENT_SESSION_TTL_DAYS=7
RATE_LIMIT_PUBLIC_AGENT_SESSION=30/minute
RATE_LIMIT_PUBLIC_AGENT_TURN=60/minute

# Agent backend: stub | gemini | anthropic | groq | auto
# auto: Gemini if GOOGLE_API_KEY, else Anthropic if ANTHROPIC_API_KEY, else Groq if GROQ_API_KEY, else stub.
AGENT_BACKEND=auto
# Max user+assistant turn pairs from chat history included in the model prompt (owner sites may store more in the DB).
AGENT_MODEL_HISTORY_MAX_TURNS=30

# Google Gemini (Generative Language API) — used by Pydantic AI / google-genai.
# Create a key at https://aistudio.google.com/apikey — do not commit real values.
# Leave unset if you are not using Gemini locally yet.
GOOGLE_API_KEY=
# Model id for Generative Language API (e.g. gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude (https://console.anthropic.com/) — used when AGENT_BACKEND=anthropic or auto with no GOOGLE_API_KEY.
ANTHROPIC_API_KEY=
# Model id (see Anthropic docs; e.g. claude-sonnet-4-20250514)
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Anthropic prompt caching (system + tool definitions; lowers repeat input cost within TTL)
ANTHROPIC_PROMPT_CACHE=True
ANTHROPIC_PROMPT_CACHE_TTL=1h

# Groq (https://console.groq.com/keys) — used when AGENT_BACKEND=groq or auto with no prior provider key.
GROQ_API_KEY=
# Model id (see Groq docs / dashboard; e.g. llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile
