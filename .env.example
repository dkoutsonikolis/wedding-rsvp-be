# --- Docker Compose: Postgres service (not read by the FastAPI app) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_db

# --- Application ---
# Database URL
# For Docker: use 'db' as hostname (service name from docker-compose.yml)
# For local: use 'localhost' as hostname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/app_db
#
# Tests: pytest creates a separate database named app_db_test (via CREATE DATABASE);
# the Postgres user must be allowed to create databases.

# Application Settings
DEBUG=False

# uv Configuration (optional)
# Uncomment if you want uv to use your system Python (e.g., when using pyenv)
# instead of managing its own Python installation
# UV_USE_SYSTEM_PYTHON=1

# CORS Configuration
# For development: use "*" to allow all origins
# For production: specify comma-separated list of allowed origins
# Example: CORS_ORIGINS=https://example.com,https://app.example.com
CORS_ORIGINS=*
CORS_CREDENTIALS=True
CORS_METHODS=*
CORS_HEADERS=*

# Request Logging
# Set to False to disable request/response logging middleware
LOG_REQUESTS=True

# JWT (access + refresh; login and POST /api/v1/auth/refresh)
JWT_SECRET_KEY=change-this-jwt-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Auth route rate limits (slowapi; e.g. requests per minute per client IP)
RATE_LIMIT_AUTH_REGISTER=5/minute
RATE_LIMIT_AUTH_LOGIN=10/minute
RATE_LIMIT_AUTH_REFRESH=30/minute
